# replica-sync configuration file
# Copy to config/sync.conf and edit for your environment.
# sync.conf is listed in .gitignore (may contain sensitive paths).

# ── Internal repository (GHE) ────────────────────────────────

# Local path to the internal monorepo (absolute path)
INTERNAL_REPO="/path/to/internal-monorepo"

# Remote name on GHE
INTERNAL_REMOTE="origin"

# Primary development branch (main, dev, master, etc.)
INTERNAL_BRANCH="main"

# GHE hostname (used as GH_HOST for the gh CLI)
GH_HOST="github.your-company.com"

# GHE Organization / Repo
GH_ORG="org"
GH_REPO="internal"

# ── Sync settings ─────────────────────────────────────────────

# Squash commit author identity (replaces internal developer info)
SYNC_AUTHOR_NAME="Platform Sync Bot"
SYNC_AUTHOR_EMAIL="sync-bot@your-company.com"

# Paths excluded from replica sync (internal-only services, etc.)
#
# These are git pathspec patterns — NOT .gitignore patterns.
# They are passed to `git archive` and `git diff` as `:!<pattern>`.
#
# Pattern rules:
#   services/internal-only/   — exclude a directory and everything under it
#                               (trailing slash matches directories)
#   .internal/                — exclude a top-level directory
#   scripts/internal/         — exclude a subdirectory
#   "**/*.secret"             — glob: exclude all *.secret files anywhere in the tree
#   "docs/INTERNAL_*.md"      — glob: exclude files matching a prefix pattern
#
# Unlike .gitignore, these patterns are repository-root-anchored and
# do not support negation (! prefix) or comment lines (# prefix).
#
# ⚠ LIMITATION — "exclude a directory except for specific files" is NOT supported.
#
#   These patterns are glob-based, not regular expressions.
#   Git pathspec does not support negative lookahead or re-inclusion after exclusion.
#   Once a path is matched by an exclusion pattern, it cannot be un-excluded.
#
#   DOES NOT WORK:
#     EXCLUDE_PATHS=(".github/workflows/")
#     INCLUDE_PATHS=(".github/workflows/sync-to-wiki-main.yml")  # ignored by git
#
#   CORRECT APPROACH — list each file to exclude individually:
#     EXCLUDE_PATHS=(
#       ".github/workflows/_deploy-docs.yml"
#       ".github/workflows/_deploy-service.yml"
#       ".github/workflows/dev-release.yml"
#       ".github/workflows/sync-replica.yml"
#       # sync-to-wiki-main.yml is NOT listed → it is included in the replica
#     )
#
#   See docs/decisions.md for the full analysis of this constraint.
EXCLUDE_PATHS=(
  "services/internal-only/"
  ".internal/"
  "scripts/internal/"
)

# ── Patch mode settings ───────────────────────────────────────

# Output directory for patch sets generated in patch mode
PATCH_OUTPUT_DIR="./sync-patches"

# ── Per-party replica settings ────────────────────────────────
# Replica-specific settings (REPLICA_REPO, REPLICA_REMOTE, REPLICA_BRANCH,
# REPLICA_GH_REPO) are defined per party in config/party/<party>.conf.
# Copy config/party/party.conf.example to config/party/<party>.conf and edit it.
